library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity audio_top is
    Port (
        CLOCK_50 : in STD_LOGIC;        -- 50 MHz clock from DE10
        KEY0     : in STD_LOGIC;        -- push button
        I2S_SCLK : out STD_LOGIC;       -- I2S clock
        I2S_WS   : out STD_LOGIC;       -- I2S word select
        I2S_SD   : out STD_LOGIC        -- I2S data
    );
end audio_top;

architecture Behavioral of audio_top is

    signal play : STD_LOGIC := '0';

begin

    -- Trigger playback when push button is pressed
    process(CLOCK_50)
    begin
        if rising_edge(CLOCK_50) then
            if KEY0 = '0' then  -- buttons are usually active low
                play <= '1';
            else
                play <= '0';
            end if;
        end if;
    end process;

    -- Instantiate your audio module (from GitHub)
    audio_inst: entity work.audio_module
        port map (
            clk     => CLOCK_50,
            play    => play,
            i2s_sclk => I2S_SCLK,
            i2s_ws   => I2S_WS,
            i2s_sd   => I2S_SD
        );

end Behavioral;
