library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity i2s_tx is
port (
clk_50       : in std_logic;         -- 50 MHz FPGA clock
reset_n      : in std_logic;
start_tx     : in std_logic;         -- trigger after config done
i2s_bclk     : out std_logic;
i2s_lrck     : out std_logic;
i2s_sdata    : out std_logic;
sample_in    : in std_logic_vector(15 downto 0)  -- one channel audio sample
);
end i2s_tx;

architecture fsm of i2s_tx is
signal bit_cnt    : integer range 0 to 15 := 0;
signal lrck_reg   : std_logic := '0';
signal sdata_reg  : std_logic := '0';
signal sending    : std_logic := '0';
signal clk_div    : integer range 0 to 20 := 0;  -- for generating BCLK (~1.536 MHz if clk_50)
begin

-- BCLK generation  
process(clk_50)  
begin  
    if rising_edge(clk_50) then  
        if clk_div < 16 then  -- adjust divider for correct BCLK  
            clk_div <= clk_div + 1;  
        else  
            clk_div <= 0;  
            i2s_bclk <= not i2s_bclk;  
        end if;  
    end if;  
end process;  

-- I2S FSM  
process(clk_50, reset_n)  
begin  
    if reset_n = '0' then  
        sending <= '0';  
        bit_cnt <= 15;  
        lrck_reg <= '0';  
        i2s_sdata <= '0';  
        i2s_lrck <= '0';  
    elsif rising_edge(clk_50) then  
        if start_tx = '1' then  
            sending <= '1';  
        end if;  

        if sending = '1' and rising_edge(i2s_bclk) then  
            i2s_sdata <= sample_in(bit_cnt);  
            if bit_cnt = 0 then  
                bit_cnt <= 15;  
                lrck_reg <= not lrck_reg;  
                i2s_lrck <= lrck_reg;  
            else  
                bit_cnt <= bit_cnt - 1;  
            end if;  
        end if;  
    end if;  
end process;  

end fsm;
