library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity top_audio is
    port(
        clk_50     : in  std_logic;
        reset_n    : in  std_logic;
        start_cfg  : in  std_logic;   -- switch to trigger codec config
        i2s_bclk   : out std_logic;
        i2s_lrck   : out std_logic;
        i2s_sdata  : out std_logic
    );
end top_audio;

architecture rtl of top_audio is

    signal config_done : std_logic;
    signal i2c_busy    : std_logic;
    signal i2c_done    : std_logic;
    signal i2c_send    : std_logic;
    signal i2c_addr    : std_logic_vector(7 downto 0);
    signal i2c_data    : std_logic_vector(15 downto 0);
    signal audio_sample: std_logic_vector(15 downto 0) := (others=>'0');  -- example sample

begin

    -- Codec configuration FSM
    cfg_inst : entity work.codec_config
        port map(
            clk_50       => clk_50,
            reset_n      => reset_n,
            start_cfg    => start_cfg,
            i2c_busy     => i2c_busy,
            i2c_done     => i2c_done,
            i2c_send_flag=> i2c_send,
            i2c_addr     => i2c_addr,
            i2c_data     => i2c_data
        );

    -- You’d need a process inside codec_config to assert config_done when done:
    config_done <= '1' when codec_config.state = DONE else '0';

    -- I2S transmitter, triggered when config is done
    i2s_inst : entity work.i2s_tx
        port map(
            clk_50    => clk_50,
            reset_n   => reset_n,
            start_tx  => config_done,   -- starts sending audio once codec is ready
            i2s_bclk  => i2s_bclk,
            i2s_lrck  => i2s_lrck,
            i2s_sdata => i2s_sdata,
            sample_in => audio_sample
        );

end rtl;
